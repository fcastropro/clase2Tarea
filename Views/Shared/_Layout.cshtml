<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRUD Clientes .NET</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="topbar">
        <div class="container">
            <h1>CRUD Clientes - ASP.NET Core MVC + MySQL</h1>
            <p>POO, método GET para búsqueda y POST para registro, edición y eliminación.</p>
        </div>
    </header>
    <main class="container">
        @RenderBody()
    </main>
    <footer class="footer">
        <div class="container">Uniandes - Aplicaciones Web</div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
