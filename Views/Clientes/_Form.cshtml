@model Cliente
<div asp-validation-summary="ModelOnly" class="error"></div>

<div class="grid">
    <div>
        <label asp-for="Cedula"></label>
        <input asp-for="Cedula" maxlength="10" />
        <span asp-validation-for="Cedula" class="error"></span>
    </div>
    <div>
        <label asp-for="Nombre"></label>
        <input asp-for="Nombre" />
        <span asp-validation-for="Nombre" class="error"></span>
    </div>
    <div>
        <label asp-for="Apellido"></label>
        <input asp-for="Apellido" />
        <span asp-validation-for="Apellido" class="error"></span>
    </div>
    <div>
        <label asp-for="Correo"></label>
        <input asp-for="Correo" type="email" />
        <span asp-validation-for="Correo" class="error"></span>
    </div>
    <div>
        <label asp-for="Telefono"></label>
        <input asp-for="Telefono" />
        <span asp-validation-for="Telefono" class="error"></span>
    </div>
    <div>
        <label asp-for="Direccion"></label>
        <input asp-for="Direccion" />
        <span asp-validation-for="Direccion" class="error"></span>
    </div>
</div>
